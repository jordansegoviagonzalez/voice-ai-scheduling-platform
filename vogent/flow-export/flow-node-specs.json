{
  "artifact_type": "vogent-flow-builder-node-specification",
  "direct_import": false,
  "reason_not_direct_import": "Workspace-scoped function IDs and versioned prompt identifiers are required.",
  "official_schema_reference": "https://docs.vogent.ai/developers/schemas",
  "ordered_nodes": [
    { "id": "greeting", "type": "freeform", "nodeData": { "prompt": "Greet the caller, state that you can help schedule an orthopedic appointment, and ask for one item at a time." } },
    { "id": "patient_status", "type": "question", "nodeData": { "question": "Are you a new patient or have you visited this facility before?", "questionType": "multiple_choice", "options": ["New", "Returning"], "clarificationDetails": "Returning to the facility does not automatically mean returning to every physician." } },
    { "id": "date_of_birth", "type": "question", "nodeData": { "question": "What is your date of birth?", "questionType": "freeform", "clarificationDetails": "Normalize to YYYY-MM-DD before the patient lookup function." } },
    { "id": "patient_lookup", "type": "function_call", "nodeData": { "functionId": "{{VOGENT_PATIENT_LOOKUP_FUNCTION_ID}}", "inputs": [{ "name": "phone", "value": "{{caller_phone}}" }, { "name": "date_of_birth", "value": "{{node.date_of_birth.output}}" }], "outputs": [{ "type": "BOOLEAN", "name": "found", "nullable": false, "description": "Whether a matching patient exists" }, { "type": "INTEGER", "name": "patient_id", "nullable": true, "description": "Internal patient ID" }] } },
    { "id": "body_part", "type": "question", "nodeData": { "question": "Which body part needs care?", "questionType": "multiple_choice", "options": ["Knee", "Hip", "Shoulder", "Hand/Wrist", "Foot/Ankle", "Spine"] } },
    { "id": "issue_type", "type": "question", "nodeData": { "question": "Is this for a fracture, joint replacement, sports injury, or general pain or consultation?", "questionType": "multiple_choice", "options": ["Fracture", "Joint Replacement", "Sports Medicine", "General"] } },
    { "id": "preferred_doctor", "type": "question", "nodeData": { "question": "Do you have a preferred physician?", "questionType": "freeform", "clarificationDetails": "This preference is optional and must still pass backend eligibility checks." } },
    { "id": "preferred_location", "type": "question", "nodeData": { "question": "Do you have a preferred clinic location?", "questionType": "multiple_choice", "options": ["Main Campus", "North Clinic", "Westside Office", "No preference"] } },
    { "id": "routing", "type": "function_call", "nodeData": { "functionId": "{{VOGENT_ROUTING_FUNCTION_ID}}", "inputs": [{ "name": "call_id", "value": "{{internal_call_id}}" }, { "name": "patient_id", "value": "{{node.patient_lookup.patient_id}}" }, { "name": "patient_status", "value": "{{node.patient_status.output}}" }, { "name": "body_part", "value": "{{node.body_part.output}}" }, { "name": "issue_type", "value": "{{node.issue_type.output}}" }, { "name": "preferred_doctor_id", "value": "{{preferred_doctor_id}}" }, { "name": "preferred_location_id", "value": "{{preferred_location_id}}" }], "outputs": [{ "type": "STRING", "name": "summary", "nullable": false, "description": "Caller-safe explanation" }, { "type": "CUSTOM", "name": "available_slots", "nullable": false, "description": "Open slots returned by the backend", "customFieldJsonSchema": "{\"type\":\"array\"}" }] } },
    { "id": "offer_slots", "type": "freeform", "nodeData": { "prompt": "Read the backend summary. Offer no more than three real slots. Explain any invalid physician or location preference in plain language. Ask the caller to choose one." } },
    { "id": "confirmation", "type": "question", "nodeData": { "question": "To confirm: you selected the stated physician, location, date, and time. Should I book it now?", "questionType": "multiple_choice", "options": ["Yes", "No"] } },
    { "id": "confirm_slot", "type": "function_call", "nodeData": { "functionId": "{{VOGENT_CONFIRM_SLOT_FUNCTION_ID}}", "inputs": [{ "name": "call_id", "value": "{{internal_call_id}}" }, { "name": "patient_id", "value": "{{node.patient_lookup.patient_id}}" }, { "name": "slot_id", "value": "{{selected_slot_id}}" }, { "name": "body_part", "value": "{{node.body_part.output}}" }, { "name": "issue_type", "value": "{{node.issue_type.output}}" }], "outputs": [{ "type": "BOOLEAN", "name": "confirmed", "nullable": false, "description": "True after backend caller-confirmation persistence" }, { "type": "STRING", "name": "confirmation_token", "nullable": false, "description": "Required token for the booking function" }] } },
    { "id": "booking", "type": "function_call", "nodeData": { "functionId": "{{VOGENT_BOOK_FUNCTION_ID}}", "inputs": [{ "name": "call_id", "value": "{{internal_call_id}}" }, { "name": "patient_id", "value": "{{node.patient_lookup.patient_id}}" }, { "name": "slot_id", "value": "{{selected_slot_id}}" }, { "name": "body_part", "value": "{{node.body_part.output}}" }, { "name": "issue_type", "value": "{{node.issue_type.output}}" }, { "name": "confirmation_token", "value": "{{node.confirm_slot.confirmation_token}}" }], "outputs": [{ "type": "BOOLEAN", "name": "booked", "nullable": false, "description": "True only after a committed database transaction" }, { "type": "STRING", "name": "doctor_name", "nullable": false, "description": "Confirmed physician" }, { "type": "STRING", "name": "location_name", "nullable": false, "description": "Confirmed location" }, { "type": "STRING", "name": "starts_at", "nullable": false, "description": "Confirmed ISO-8601 start time" }] } },
    { "id": "closing", "type": "freeform", "nodeData": { "prompt": "Only after booked is true, repeat the confirmed physician, location, date, and time, thank the caller, and close the call." } }
  ]
}
